APP_NAME=
APP_ENV=
APP_KEY=
APP_DEBUG=
APP_URL=

APP_LOCALE=
APP_FALLBACK_LOCALE=
APP_FAKER_LOCALE=

APP_MAINTENANCE_DRIVER=
# APP_MAINTENANCE_STORE=database

GROQ_API_KEY=your_new_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=20

# Security controls
ADMIN_SEED_PASSWORD=change-this-local-admin-password
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
SECURITY_HEADERS_ENABLED=true
SECURITY_CSP_ENABLED=true
SECURITY_CSP=
SECURITY_CSP_EXTRA_CONNECT=
SECURITY_CSP_EXTRA_IMG=
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
WEBHOOK_SECRET=change-this-webhook-secret
WEBHOOK_SIGNATURE_HEADER=X-TK-Signature
WEBHOOK_TIMESTAMP_HEADER=X-TK-Timestamp
WEBHOOK_TOLERANCE_SECONDS=300

# Rate limits: max attempts per decay window in minutes
RATE_LIMIT_PUBLIC_MAX=120
RATE_LIMIT_PUBLIC_DECAY=1
RATE_LIMIT_API_MAX=60
RATE_LIMIT_API_DECAY=1
RATE_LIMIT_AUTH_MAX=8
RATE_LIMIT_AUTH_DECAY=1
RATE_LIMIT_ADMIN_MAX=60
RATE_LIMIT_ADMIN_DECAY=1
RATE_LIMIT_PAYMENT_MAX=10
RATE_LIMIT_PAYMENT_DECAY=1
RATE_LIMIT_UPLOAD_MAX=12
RATE_LIMIT_UPLOAD_DECAY=1
RATE_LIMIT_CHUNK_UPLOAD_MAX=240
RATE_LIMIT_CHUNK_UPLOAD_DECAY=1
RATE_LIMIT_CHATBOT_MAX=12
RATE_LIMIT_CHATBOT_DECAY=1
RATE_LIMIT_WEBHOOK_MAX=60
RATE_LIMIT_WEBHOOK_DECAY=1

# Chunked uploads for large browser uploads
CHUNK_UPLOAD_ENABLED=true
CHUNK_UPLOAD_SIZE_MB=3
CHUNK_UPLOAD_TEMP_DIR=storage/app/chunks
CHUNK_UPLOAD_MAX_FILE_SIZE_MB=25
CHUNK_UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,webp,pdf
CHUNK_UPLOAD_CLEANUP_MINUTES=60
CHUNK_UPLOAD_MAX_ACTIVE_PER_USER=5
CHUNK_UPLOAD_MAX_PARALLEL=3
CHUNK_UPLOAD_RETRY_ATTEMPTS=3

# PHP_CLI_SERVER_WORKERS is disabled for local Windows development.
# PHP's built-in server can fail to bind when this is set.

BCRYPT_ROUNDS=

LOG_CHANNEL=
LOG_STACK=
LOG_DEPRECATIONS_CHANNEL=
LOG_LEVEL=

DB_CONNECTION=
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=
SESSION_LIFETIME=
SESSION_ENCRYPT=
SESSION_PATH=
SESSION_DOMAIN=

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=
QUEUE_CONNECTION=

CACHE_STORE=
CACHE_DRIVER=
# CACHE_PREFIX=

MEMCACHED_HOST=

REDIS_CLIENT=
REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=

# Realtime WebSockets (Laravel Reverb)
# For Railway, deploy Reverb as a separate service with:
# php artisan reverb:start --host=0.0.0.0 --port=$PORT
REVERB_APP_ID=local-app
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
VITE_REVERB_ENABLED=false

MAIL_MAILER=
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=

# Cloudflare R2 (S3-compatible object storage) — primary file storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_URL=
R2_REGION=auto
R2_MAX_FILE_SIZE_KB=16384
CAMPAIGN_IMAGE_MAX_SIZE_KB=15360
R2_CONVERT_IMAGES_TO_WEBP=true
R2_WEBP_NODE_BINARY=node
R2_WEBP_CONVERSION_TIMEOUT=60
R2_WEBP_MAX_WIDTH=2048
R2_WEBP_MAX_HEIGHT=2048
R2_WEBP_MAX_QUALITY=0.82
R2_WEBP_MIN_QUALITY=0.45

# MongoDB (optional — scaffolded for future migration from SQLite)
MONGODB_URI=
MONGODB_DB_NAME=

VITE_APP_NAME=
VITE_MAP_TILE_URL=
VITE_MAP_TILE_ATTRIBUTION=
VITE_MAPTILER_API_KEY=
VITE_NOMINATIM_BASE_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ===================================================================
# Automated ID Verification (config/id_verification.php)
# ===================================================================
# Active provider. Supported values: didit, ocr_space, google_vision, none.
ID_VERIFICATION_PROVIDER=ocr_space
ID_VERIFICATION_ENABLED=true

# Score thresholds (0-100). Submissions above auto_approve are verified
# automatically. Submissions in the middle band are queued for admin review.
ID_AUTO_APPROVE_SCORE=85
ID_MANUAL_REVIEW_SCORE=60

# Per-user upload constraints (in addition to throttle:upload middleware).
ID_MAX_FILE_SIZE_MB=5
ID_ALLOWED_TYPES=jpg,jpeg,png,webp
ID_VERIFICATION_MAX_ATTEMPTS_PER_DAY=5

# Liveness / face match (only honored by providers that support it, e.g. Didit).
ID_REQUIRE_LIVENESS=false

# Free-tier quota guards — when these caps are reached, submissions go
# to manual review (admin queue) instead of calling the provider. Tune
# the defaults to stay below each provider's free-tier ceiling.
ID_QUOTA_OCR_SPACE_DAILY=400
ID_QUOTA_OCR_SPACE_MONTHLY=20000
ID_QUOTA_GOOGLE_VISION_DAILY=50
ID_QUOTA_GOOGLE_VISION_MONTHLY=900
ID_QUOTA_DIDIT_DAILY=30
ID_QUOTA_DIDIT_MONTHLY=500

# Provider: Didit (free KYC tier — supports liveness + face match)
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
DIDIT_BASE_URL=https://verification.didit.me
DIDIT_WEBHOOK_SECRET=
DIDIT_WEBHOOK_URL=https://your-domain.com/webhooks/didit
DIDIT_CALLBACK_URL=https://your-domain.com/verification/didit/callback
DIDIT_TIMEOUT=30

# Provider: OCR.Space (free OCR — 25k requests/month, 1MB max file)
OCR_SPACE_API_KEY=
OCR_SPACE_BASE_URL=https://api.ocr.space/parse/image
OCR_SPACE_ENGINE=2
OCR_SPACE_LANGUAGE=eng
OCR_SPACE_TIMEOUT=30
OCR_SPACE_MAX_UPLOAD_KB=1024

# Provider: Google Cloud Vision (free tier — 1000 units/month)
GOOGLE_VISION_API_KEY=
GOOGLE_VISION_BASE_URL=https://vision.googleapis.com/v1/images:annotate
GOOGLE_VISION_TIMEOUT=30
